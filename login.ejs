<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <title>SMM Panel - Kirish</title>
</head>
<body class="bg-dark text-white">
    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <div class="card p-4 bg-secondary shadow-lg" style="width: 400px;">
            <h2 class="text-center text-warning">SMM PANEL</h2>
            <ul class="nav nav-tabs mb-3" id="myTab">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#login">Kirish</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#reg">Ro'yxatdan o'tish</button></li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="login">
                    <form action="/auth/login" method="POST">
                        <input type="text" name="username" class="form-control mb-3" placeholder="Login" required>
                        <input type="password" name="password" class="form-control mb-3" placeholder="Parol" required>
                        <button class="btn btn-warning w-100">Kirish</button>
                    </form>
                </div>
                <div class="tab-pane fade" id="reg">
                    <form action="/auth/register" method="POST">
                        <input type="text" name="username" class="form-control mb-3" placeholder="Yangi Login" required>
                        <input type="password" name="password" class="form-control mb-3" placeholder="Yangi Parol" required>
                        <button class="btn btn-success w-100">Yaratish</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>