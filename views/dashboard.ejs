<!DOCTYPE html>
<html lang="uz">
<head>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background: #0f0f0f; color: white; }
        .gold-card { border: 1px solid #ffd700; background: #1a1a1a; border-radius: 15px; }
        
        /* Floating Telegram Button - Chekkadagi tugma */
        #tg-sync-wrapper {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            display: none; /* Faqat bog'lanmagan bo'lsa chiqadi */
        }
        .btn-tg {
            background: #0088cc;
            color: white;
            border-radius: 50px;
            padding: 10px 20px;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 136, 204, 0.4);
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="container mt-5">
    <div class="gold-card p-4">
        <h2>Xush kelibsiz, <%= user.username %>!</h2>
        <hr color="gold">
        <div class="row mt-4">
            <div class="col-6">
                <p class="text-secondary m-0">Balans (Stars):</p>
                <h3 class="text-warning">⭐️ <%= user.balance || 0 %></h3>
            </div>
            <div class="col-6 text-end">
                <p class="text-secondary m-0">Telegram Holati:</p>
                <h5 id="status-text">
                    <%= user.tg_id ? "✅ Bog'langan: @" + user.tg_username : "❌ Bog'lanmagan" %>
                </h5>
            </div>
        </div>
    </div>
</div>

<div id="tg-sync-wrapper">
    <button onclick="linkTelegram()" class="btn-tg">
        <img src="https://upload.wikimedia.org/wikipedia/commons/8/82/Telegram_logo.svg" width="20" class="me-2">
        Sync with Telegram
    </button>
</div>

<script>
    const tg = window.Telegram.WebApp;
    const isLinked = "<%= user.tg_id %>" !== "";

    // Agar foydalanuvchi hali bog'lanmagan bo'lsa va sayt Telegram ichida ochilgan bo'lsa
    if (!isLinked && tg.initDataUnsafe.user) {
        document.getElementById('tg-sync-wrapper').style.display = 'block';
    }

    async function linkTelegram() {
        const user = tg.initDataUnsafe.user;
        if (!user) return alert("Faqat Telegram ichida ishlaydi!");

        const response = await fetch('/api/link-telegram', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                tg_id: user.id,
                tg_username: user.username,
                tg_first_name: user.first_name
            })
        });

        const result = await response.json();
        if (result.success) {
            alert("Muvaffaqiyatli bog'landi!");
            location.reload();
        }
    }
</script>
</body>
</html>
