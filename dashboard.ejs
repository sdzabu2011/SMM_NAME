<!DOCTYPE html>
<html>
<head>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container py-4">
        <div class="card p-3 border-warning mb-4 shadow-sm">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <img id="dash-photo" src="" class="rounded-circle me-3 border border-warning" width="50">
                    <div>
                        <h5 class="m-0 gold-text" id="dash-name">User</h5>
                        <small class="text-secondary">Telegram Verified ✅</small>
                    </div>
                </div>
                <div class="text-end">
                    <div class="badge bg-warning text-dark p-2">
                        <span id="star-balance">0</span> ⭐️ STARS
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="card p-4 border-warning h-100">
                    <h4 class="gold-text">New Order</h4>
                    <form action="/order/new" method="POST">
                        <select name="service" class="form-select bg-dark text-white border-secondary mb-3">
                            <option value="TG Subs">Telegram Members (100 = 700 ⭐️)</option>
                            <option value="TG Views">Post Views (1000 = 50 ⭐️)</option>
                        </select>
                        <input type="text" name="link" class="form-control bg-dark text-white border-secondary mb-3" placeholder="https://t.me/your_channel">
                        <input type="number" name="qty" id="qty-input" class="form-control bg-dark text-white border-secondary mb-3" placeholder="Quantity">
                        <button class="btn btn-gold w-100">ORDER NOW</button>
                    </form>
                </div>
            </div>
            <div class="col-md-6 mt-4 mt-md-0">
                <h4 class="gold-text">Recent Orders</h4>
                <div class="card bg-dark border-secondary p-2">
                    <table class="table table-dark table-hover m-0">
                        <thead><tr><th>Service</th><th>Qty</th><th>Status</th></tr></thead>
                        <tbody id="order-list">
                            <% orders.forEach(o => { %>
                                <tr>
                                    <td><%= o.service %></td>
                                    <td><%= o.qty %></td>
                                    <td><span class="badge bg-secondary"><%= o.status %></span></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script>
        const tele = window.Telegram.WebApp;
        const user = tele.initDataUnsafe?.user;
        if (user) {
            document.getElementById('dash-name').innerText = user.first_name;
            if (user.photo_url) document.getElementById('dash-photo').src = user.photo_url;
        }
    </script>
</body>
</html>
