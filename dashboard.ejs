<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <title>Kabinet - SMM Panel</title>
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-primary mb-4">
        <div class="container">
            <span class="navbar-brand">Salom, <%= user.username %>! | Balans: <b><%= balance %> ⭐ Star</b></span>
            <a href="/" class="btn btn-danger btn-sm">Chiqish</a>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="card p-3 shadow-sm mb-4">
                    <h4>Yangi Buyurtma</h4>
                    <form action="/order/new" method="POST">
                        <select name="service" class="form-select mb-3">
                            <option value="Telegram Obunachi">Telegram Obunachi (1k = 200 Star)</option>
                            <option value="Telegram Boost">Telegram Boost (1 ta = 2 Star)</option>
                            <option value="Telegram Star Xizmati">Telegram Star Xizmati</option>
                        </select>
                        <input type="text" name="link" class="form-control mb-3" placeholder="Havola: https://t.me/..." required>
                        <input type="number" name="qty" class="form-control mb-3" placeholder="Soni" required>
                        <button class="btn btn-primary w-100">Buyurtma Berish</button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <h4>Buyurtmalar Tarixi</h4>
                <div class="table-responsive">
                    <table class="table table-white table-hover shadow-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>Xizmat</th>
                                <th>Soni</th>
                                <th>Star</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                            <tr>
                                <td><%= order.service %></td>
                                <td><%= order.qty %></td>
                                <td><%= order.price %> ⭐</td>
                                <td>
                                    <span class="badge 
                                        <%= order.status == 'kutilmoqda' ? 'bg-secondary' : '' %>
                                        <%= order.status == 'jarayonda' ? 'bg-info' : '' %>
                                        <%= order.status == 'bajarildi' ? 'bg-success' : '' %>
                                        <%= order.status == 'qisman' ? 'bg-warning text-dark' : '' %>">
                                        <%= order.status.toUpperCase() %>
                                    </span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>