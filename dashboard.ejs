<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="/style.css">
    <title>SMM Gold - Kabinet</title>
</head>
<body>
    <nav class="navbar navbar-dark border-bottom border-warning mb-4">
        <div class="container">
            <span class="navbar-brand gold-text">SMM GOLD PANEL</span>
            <span class="text-white">Balans: <b class="gold-text"><%= user.balance %> ⭐</b></span>
        </div>
    </nav>

    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card p-3">
                    <h5 class="gold-text">Buyurtma berish</h5>
                    <form action="/order/new" method="POST">
                        <label class="small">Xizmat:</label>
                        <select name="service" class="form-select form-control mb-3">
                            <option value="Telegram Obunachi">Telegram Obunachi (10ta = 70⭐)</option>
                            <option value="Telegram Boost">Telegram Boost (1ta = 20⭐)</option>
                        </select>
                        <input type="text" name="link" class="form-control mb-2" placeholder="Link (t.me/...)" required>
                        <input type="number" name="qty" class="form-control mb-3" placeholder="Soni" required>
                        <button class="btn btn-gold w-100">SOTIB OLISH</button>
                    </form>
                    <hr class="border-warning">
                    <p class="small text-center">Balans to'ldirish uchun Adminga murojaat qiling.</p>
                </div>
            </div>
            <div class="col-md-8">
                <h5 class="gold-text">Buyurtmalar tarixi</h5>
                <div class="card p-2">
                    <table class="table table-hover">
                        <thead><tr><th>Xizmat</th><th>Soni</th><th>Narxi</th><th>Status</th></tr></thead>
                        <tbody>
                            <% orders.forEach(o => { %>
                            <tr>
                                <td><%= o.service %></td>
                                <td><%= o.qty %></td>
                                <td><%= o.price %> ⭐</td>
                                <td><span class="badge badge-<%= o.status %>"><%= o.status %></span></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
